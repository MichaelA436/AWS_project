    connection_type="s3",
    format="csv",
    connection_options={"paths": ["s3://michael1-s3-bucket/bronze/toprocess/movies/"]},
    transformation_ctx="Movies_raw"
)

Movies_mapped = ApplyMapping.apply(
    frame=Movies_raw,
    mappings=[
        ("movie_id", "string", "movie_id", "string"),
        ("title", "string", "title", "string"),
        ("content_type", "string", "content_type", "string"),
        ("genre_primary", "string", "genre_primary", "string"),
        ("release_year", "string", "release_year", "int"),
        ("duration_minutes", "string", "duration_minutes", "double"),
        ("country_of_origin", "string", "country_of_origin", "string"),
        ("imdb_rating", "string", "imdb_rating", "double"),
        ("is_netflix_original", "string", "is_netflix_original", "boolean"),
        ("added_to_platform", "string", "added_to_platform", "date"),
