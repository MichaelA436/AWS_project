import sys
from awsglue.transforms import *
from awsglue.utils import getResolvedOptions
from pyspark.context import SparkContext
from awsglue.context import GlueContext
from awsglue.job import Job
from awsgluedq.transforms import EvaluateDataQuality
from awsglue.dynamicframe import DynamicFrame
from awsglue import DynamicFrame
from pyspark.sql.functions import trim, col

def sparkSqlQuery(glueContext, query, mapping, transformation_ctx) -> DynamicFrame:
    for alias, frame in mapping.items():
        frame.toDF().createOrReplaceTempView(alias)
    result = spark.sql(query)
    return DynamicFrame.fromDF(result, glueContext, transformation_ctx)

args = getResolvedOptions(sys.argv, ['JOB_NAME'])
sc = SparkContext()
glueContext = GlueContext(sc)
spark = glueContext.spark_session
job = Job(glueContext)
job.init(args['JOB_NAME'], args)

DEFAULT_DATA_QUALITY_RULESET = """
    Rules = [
        ColumnCount > 0
    ]
"""

# ============================================================
# USERS CLEANING
# ============================================================

Users_raw = glueContext.create_dynamic_frame.from_options(
    format_options={"withHeader": True, "separator": ","},
    connection_type="s3",
    format="csv",
    connection_options={"paths": ["s3://michael1-s3-bucket/bronze/toprocess/users/"]},
    transformation_ctx="Users_raw"
)

Users_mapped = ApplyMapping.apply(
    frame=Users_raw,
    mappings=[
        ("user_id", "string", "user_id", "string"),
        ("email", "string", "email", "string"),
        ("first_name", "string", "first_name", "string"),
        ("last_name", "string", "last_name", "string"),
        ("age", "string", "age", "double"),
        ("gender", "string", "gender", "string"),
        ("country", "string", "country", "string"),
        ("state_province", "string", "state_province", "string"),
        ("city", "string", "city", "string"),
        ("subscription_plan", "string", "subscription_plan", "string"),
        ("subscription_start_date", "string", "subscription_start_date", "date"),
        ("is_active", "string", "is_active", "boolean"),
        ("monthly_spend", "string", "monthly_spend", "double"),
        ("primary_device", "string", "primary_device", "string"),
        ("household_size", "string", "household_size", "double"),
        ("created_at", "string", "created_at", "timestamp")
    ],
    transformation_ctx="Users_mapped"
)

Users_clean = DynamicFrame.fromDF(
    Users_mapped.toDF().dropDuplicates(["user_id", "created_at"]),
    glueContext,
    "Users_clean"
)

EvaluateDataQuality().process_rows(
    frame=Users_clean,
    ruleset=DEFAULT_DATA_QUALITY_RULESET,
    publishing_options={"dataQualityEvaluationContext": "DQ_users", "enableDataQualityResultsPublishing": True},
)

glueContext.write_dynamic_frame.from_options(
    frame=Users_clean,
    connection_type="s3",
    format="glueparquet",
    connection_options={"path": "s3://michael1-s3-bucket/silver/users/", "partitionKeys": []},
    format_options={"compression": "snappy"},
    transformation_ctx="Users_to_Silver"
)

# ============================================================
# MOVIES CLEANING
# ============================================================

Movies_raw = glueContext.create_dynamic_frame.from_options(
