# ============================================================
# WATCH_HISTORY_INITIAL_LOAD CLEANING
# ============================================================

Watch_raw = glueContext.create_dynamic_frame.from_options(
    format_options={"withHeader": True, "separator": ","},
    connection_type="s3",
    format="csv",
    connection_options={"paths": ["s3://michael1-s3-bucket/bronze/toprocess/watch_history_initial_load/"]},
    transformation_ctx="Watch_raw"
)

Watch_df = Watch_raw.toDF()

Watch_clean_df = (
    Watch_df
    .withColumn("session_id", trim(col("session_id")))
    .withColumn("user_id", trim(col("user_id")))
    .withColumn("movie_id", trim(col("movie_id")))
    .withColumn("watch_date", col("watch_date").cast("date"))
    .withColumn("device_type", trim(col("device_type")))
    .withColumn("watch_duration_minutes", col("watch_duration_minutes").cast("double"))
    .withColumn("progress_percentage", col("progress_percentage").cast("double"))
    .withColumn("action", trim(col("action")))
    .withColumn("quality", trim(col("quality")))
    .withColumn("location_country", trim(col("location_country")))
    .withColumn("is_download", col("is_download").cast("boolean"))
    .withColumn("user_rating", col("user_rating").cast("int"))
    .dropDuplicates(["session_id", "user_id", "movie_id", "watch_date"])
)

Watch_clean = DynamicFrame.fromDF(Watch_clean_df, glueContext, "Watch_clean")

EvaluateDataQuality().process_rows(
    frame=Watch_clean,
    ruleset=DEFAULT_DATA_QUALITY_RULESET,
    publishing_options={"dataQualityEvaluationContext": "DQ_watch_history", "enableDataQualityResultsPublishing": True},
)

glueContext.write_dynamic_frame.from_options(
    frame=Watch_clean,
    connection_type="s3",
    format="glueparquet",
    connection_options={"path": "s3://michael1-s3-bucket/silver/watch_history/", "partitionKeys": ["watch_date"]},
    format_options={"compression": "snappy"},
    transformation_ctx="Watch_to_Silver"
)

# ============================================================

job.commit()
